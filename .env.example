# Sanity (optional — site uses static JSON until configured)
# VITE_SANITY_PROJECT_ID=your_project_id
# VITE_SANITY_DATASET=production

# Formspree (optional — forms work in demo mode without these)
# VITE_FORMSPREE_CONTACT_ID=your_contact_form_id
# VITE_FORMSPREE_CUSTOM_ORDER_ID=your_custom_order_form_id

# Paystack (server only — never prefix with VITE_)
# PAYSTACK_SECRET_KEY=sk_test_...

# Supabase customer accounts (optional — guest checkout works without these)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
